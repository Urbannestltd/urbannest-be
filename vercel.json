{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/swagger-ui-dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.ts"
    }
  ],
  "crons": [
    { "path": "/cron/reminders", "schedule": "* * * * *" },
    { "path": "/cron/walk-in-timeout", "schedule": "* * * * *" },
    { "path": "/cron/no-show", "schedule": "* * * * *" }
  ]
}
